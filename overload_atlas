    </div>
    
    <div id="settings" style="display: none;">
        <div>
            <label>Sensitivity: <input type="range" id="sensitivity" min="0.3" max="2" step="0.1" value="0.8"></label>
        </div>
        <div>
            <label><input type="checkbox" id="invertY"> Invert Y</label>
        </div>
    </div>

