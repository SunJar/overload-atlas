<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Overload Atlas - NJIT Sensory Experience Simulator</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        #container { position: relative; width: 100%; height: 100%; background: #000; cursor: pointer; }
        canvas { display: block; width: 100% !important; height: 100% !important; }
        
        /* Claude AI Windows - 3 panels */
        .claude-window {
            position: absolute;
            background: rgba(0,0,0,0.92);
            color: white;
            padding: 16px;
            border-radius: 12px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(102, 126, 234, 0.3);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        
        #claude-main {
            top: 20px; left: 20px;
            width: 340px; max-height: calc(50vh - 40px);
            overflow-y: auto;
        }
        
        #claude-tips {
            bottom: 180px; left: 20px;
            width: 300px;
        }
        
        #claude-survival {
            bottom: 20px; left: 20px;
            width: 300px;
        }
        
        .claude-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 10px;
        }
        
        .window-title {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #b5d4f4;
        }
        
        .window-content {
            font-size: 13px;
            line-height: 1.6;
            color: #ddd;
        }
        
        /* Metrics */
        .metric {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            align-items: center;
        }
        .metric-label { color: #aaa; font-size: 13px; }
        .metric-value { font-weight: 600; font-size: 16px; }
        .level-1 { color: #4caf50; }
        .level-2 { color: #8bc34a; }
        .level-3 { color: #ffc107; }
        .level-4 { color: #ff9800; }
        .level-5 { color: #f44336; }
        
        #zone-info {
            margin: 12px 0;
            padding: 10px;
            background: rgba(102, 126, 234, 0.18);
            border-radius: 8px;
            font-size: 12px;
            color: #b5d4f4;
            border: 1px solid rgba(102, 126, 234, 0.35);
        }
        
        /* Stress Meter */
        #stress-meter {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0,0,0,0.92);
            padding: 16px;
            border-radius: 12px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.12);
            width: 200px;
        }
        #stress-meter h4 {
            color: white;
            font-size: 14px;
            margin-bottom: 8px;
        }
        .stress-bar {
            width: 100%;
            height: 12px;
            background: rgba(255,255,255,0.1);
            border-radius: 6px;
            overflow: hidden;
            position: relative;
        }
        .stress-fill {
            height: 100%;
            background: linear-gradient(90deg, #4caf50, #ffc107, #f44336);
            width: 0%;
            transition: width 0.5s ease;
        }
        .stress-label {
            color: #aaa;
            font-size: 11px;
            margin-top: 6px;
        }
        
        /* Timer */
        #timer {
            position: absolute;
            top: 120px;
            right: 20px;
            background: rgba(0,0,0,0.92);
            padding: 12px 16px;
            border-radius: 12px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.12);
            color: white;
            font-size: 13px;
        }
        
        /* Mini Map */
        #minimap {
            position: absolute;
            bottom: 20px;
            right: 20px;
            width: 150px;
            height: 150px;
            background: rgba(0,0,0,0.92);
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.12);
            backdrop-filter: blur(12px);
        }
        #minimap-canvas {
            width: 100%;
            height: 100%;
            border-radius: 12px;
        }
        
        /* Room Label */
        #room-label {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.92);
            color: white;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 600;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.12);
        }
        
        /* Controls */
        #controls {
            position: absolute;
            bottom: 180px;
            right: 20px;
            background: rgba(0,0,0,0.92);
            color: white;
            padding: 16px;
            border-radius: 12px;
            font-size: 12px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.12);
        }
        #controls div { margin: 4px 0; }
        .key {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            padding: 3px 10px;
            border-radius: 4px;
            font-weight: 600;
            margin: 0 4px;
            font-size: 11px;
        }
        
        /* Settings */
        #settings {
            position: absolute;
            top: 180px;
            right: 20px;
            background: rgba(0,0,0,0.92);
            color: white;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 12px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.12);
        }
        #settings label {
            display: block;
            margin: 8px 0;
            cursor: pointer;
        }
        #settings input[type="range"] {
            width: 100px;
            margin-left: 8px;
        }
        
        /* Instruction Overlay */
        #instructions {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.95);
            color: white;
            padding: 40px;
            border-radius: 16px;
            text-align: center;
            backdrop-filter: blur(20px);
            border: 2px solid rgba(255,255,255,0.15);
            max-width: 500px;
            z-index: 1000;
        }
        #instructions h2 {
            margin-bottom: 20px;
            font-size: 28px;
        }
        #instructions p {
            margin: 12px 0;
            line-height: 1.6;
            color: #ccc;
        }
        #instructions button {
            margin-top: 24px;
            padding: 14px 32px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
        }
        #instructions button:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body>
