        function init() {
            const container = document.getElementById('container');
            
            scene = new THREE.Scene();
            scene.fog = new THREE.Fog(0x000000, 15, 60);
            
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 1.6, 0);
            
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            container.appendChild(renderer.domElement);
            
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
            
            let xOffset = 0;
            roomData.forEach((data, i) => {
                createRoom(data, xOffset);
                xOffset += data.size.x + 10;
            });
            
            document.getElementById('sensitivity').addEventListener('input', (e) => {
                sensitivity = parseFloat(e.target.value);
            });
            document.getElementById('invertY').addEventListener('change', (e) => {
                invertY = e.target.checked;
            });
            
            document.addEventListener('keydown', onKeyDown);
            document.addEventListener('keyup', onKeyUp);
            document.addEventListener('pointerlockchange', onPointerLockChange);
            
            document.getElementById('start-btn').addEventListener('click', startExperience);
            container.addEventListener('click', () => {
                if (!document.pointerLockElement) {
                    container.requestPointerLock();
                }
            });
            
            animate();
        }

        function startExperience() {
            document.getElementById('instructions').style.display = 'none';
            document.getElementById('claude-main').style.display = 'block';
            document.getElementById('claude-tips').style.display = 'block';
            document.getElementById('claude-survival').style.display = 'block';
            document.getElementById('room-label').style.display = 'block';
            document.getElementById('stress-meter').style.display = 'block';
            document.getElementById('timer').style.display = 'block';
            document.getElementById('minimap').style.display = 'block';
            document.getElementById('controls').style.display = 'block';
            document.getElementById('settings').style.display = 'block';
            
            const container = document.getElementById('container');
            container.requestPointerLock();
            
            updateHUD();
            startTimer();
        }

        function createRoom(data, xOffset) {
            const group = new THREE.Group();
            group.position.x = xOffset;
            
            const sizeX = data.size.x;
            const sizeZ = data.size.z;
            
            const floorGeo = new THREE.PlaneGeometry(sizeX, sizeZ);
            const floorMat = new THREE.MeshBasicMaterial({ color: 0x1a1a1a, side: THREE.DoubleSide });
            const floor = new THREE.Mesh(floorGeo, floorMat);
            floor.rotation.x = Math.PI / 2;
            group.add(floor);
            
            const wallMat = new THREE.MeshBasicMaterial({ color: data.wallColor, side: THREE.DoubleSide });
            const height = 5;
            
            const wall1 = new THREE.Mesh(new THREE.PlaneGeometry(sizeX, height), wallMat);
            wall1.position.z = -sizeZ/2;
            wall1.position.y = height/2;
            group.add(wall1);
            obstacles.push({ x: xOffset, z: -sizeZ/2, width: sizeX, depth: 0.5 });
            
            const wall2 = new THREE.Mesh(new THREE.PlaneGeometry(sizeX, height), wallMat);
            wall2.position.z = sizeZ/2;
            wall2.position.y = height/2;
            wall2.rotation.y = Math.PI;
            group.add(wall2);
            obstacles.push({ x: xOffset, z: sizeZ/2, width: sizeX, depth: 0.5 });
            
            const wall3 = new THREE.Mesh(new THREE.PlaneGeometry(sizeZ, height), wallMat);
            wall3.position.x = -sizeX/2;
            wall3.position.y = height/2;
            wall3.rotation.y = Math.PI / 2;
            group.add(wall3);
            obstacles.push({ x: xOffset - sizeX/2, z: 0, width: 0.5, depth: sizeZ });
            
            const wall4 = new THREE.Mesh(new THREE.PlaneGeometry(sizeZ, height), wallMat);
            wall4.position.x = sizeX/2;
            wall4.position.y = height/2;
            wall4.rotation.y = -Math.PI / 2;
            group.add(wall4);
            obstacles.push({ x: xOffset + sizeX/2, z: 0, width: 0.5, depth: sizeZ });
            
            const ceiling = new THREE.Mesh(new THREE.PlaneGeometry(sizeX, sizeZ), wallMat);
            ceiling.position.y = height;
            ceiling.rotation.x = -Math.PI / 2;
            group.add(ceiling);
            
            data.zones.forEach((zone, i) => {
                const zoneGroup = new THREE.Group();
                zoneGroup.position.set(zone.pos.x, 0, zone.pos.z);
                
                const shapes = [
                    new THREE.BoxGeometry(3, 2, 1.5),
                    new THREE.BoxGeometry(1, 2.5, 1),
                    new THREE.BoxGeometry(2, 0.8, 2),
                ];
                
                const mesh = new THREE.Mesh(shapes[i % 3], new THREE.MeshBasicMaterial({ 
                    color: data.color, transparent: true, opacity: 0.6
                }));
                mesh.position.y = 1;
                zoneGroup.add(mesh);
                
                const marker = new THREE.Mesh(new THREE.CircleGeometry(2, 32), new THREE.MeshBasicMaterial({ 
                    color: data.color, transparent: true, opacity: 0.3
                }));
                marker.rotation.x = -Math.PI / 2;
                marker.position.y = 0.01;
                zoneGroup.add(marker);
                
                group.add(zoneGroup);
                obstacles.push({ x: xOffset + zone.pos.x, z: zone.pos.z, width: 3, depth: 2 });
            });
            
            for (let i = 0; i < 8; i++) {
                const size = Math.random() * 0.5 + 0.3;
                const cube = new THREE.Mesh(new THREE.BoxGeometry(size, size * 2, size), new THREE.MeshBasicMaterial({ 
                    color: data.color, transparent: true, opacity: 0.4
                }));
                const posX = (Math.random() - 0.5) * (sizeX - 4);
                const posZ = (Math.random() - 0.5) * (sizeZ - 4);
                cube.position.set(posX, size, posZ);
                group.add(cube);
                obstacles.push({ x: xOffset + posX, z: posZ, width: size, depth: size });
            }
            
            scene.add(group);
            rooms.push({ group, data, xOffset });
        }

        function checkCollision(newX, newZ) {
            const playerRadius = 0.5;
            for (let obs of obstacles) {
                const dx = Math.abs(newX - obs.x);
                const dz = Math.abs(newZ - obs.z);
                if (dx < (obs.width/2 + playerRadius) && dz < (obs.depth/2 + playerRadius)) {
                    return true;
                }
            }
            return false;
        }

        function onKeyDown(e) {
            switch(e.code) {
                case 'KeyW': moveState.forward = true; break;
                case 'KeyS': moveState.backward = true; break;
                case 'KeyA': moveState.left = true; break;
                case 'KeyD': moveState.right = true; break;
                case 'Space': 
                    e.preventDefault();
                    switchRoom();
                    break;
            }
        }

        function onKeyUp(e) {
            switch(e.code) {
                case 'KeyW': moveState.forward = false; break;
                case 'KeyS': moveState.backward = false; break;
                case 'KeyA': moveState.left = false; break;
                case 'KeyD': moveState.right = false; break;
            }
        }

        function onPointerLockChange() {
            if (document.pointerLockElement) {
                document.addEventListener('mousemove', onMouseMove);
            } else {
                document.removeEventListener('mousemove', onMouseMove);
            }
        }

        function onMouseMove(e) {
            const movementX = e.movementX || 0;
            const movementY = e.movementY || 0;
            
            euler.setFromQuaternion(camera.quaternion);
            euler.y -= movementX * 0.002 * sensitivity;
            euler.x -= movementY * 0.002 * sensitivity * (invertY ? -1 : 1);
            euler.x = Math.max(-PI_2, Math.min(PI_2, euler.x));
            camera.quaternion.setFromEuler(euler);
        }

        function switchRoom() {
            currentRoomIndex = (currentRoomIndex + 1) % rooms.length;
            const newRoom = rooms[currentRoomIndex];
            camera.position.x = newRoom.xOffset;
            camera.position.z = 0;
            updateHUD();
            resetTimer();
        }

        function getCurrentZone() {
            const room = roomData[currentRoomIndex];
            const currentRoom = rooms[currentRoomIndex];
            const localX = camera.position.x - currentRoom.xOffset;
            const localZ = camera.position.z;
            
            let closestZone = null;
            let minDist = Infinity;
            
            room.zones.forEach(zone => {
                const dist = Math.sqrt(Math.pow(localX - zone.pos.x, 2) + Math.pow(localZ - zone.pos.z, 2));
                if (dist < minDist && dist < 5) {
                    minDist = dist;
                    closestZone = zone;
                }
            });
            
            return closestZone;
        }

        function updateHUD() {
            const room = roomData[currentRoomIndex];
            const zone = getCurrentZone();
            
            document.getElementById('noise').textContent = room.noise + '/5';
            document.getElementById('noise').className = 'metric-value level-' + room.noise;
            
            document.getElementById('light').textContent = room.light + '/5';
            document.getElementById('light').className = 'metric-value level-' + room.light;
            
            document.getElementById('crowd').textContent = room.crowd + '/5';
            document.getElementById('crowd').className = 'metric-value level-' + room.crowd;
            
            const zoneInfo = document.getElementById('zone-info');
            if (zone) {
                zoneInfo.textContent = '📍 ' + zone.name;
                zoneInfo.style.display = 'block';
                document.getElementById('main-advice').textContent = zone.advice;
                document.getElementById('tips-content').textContent = zone.tips;
                document.getElementById('survival-content').textContent = zone.survival;
            } else {
                zoneInfo.style.display = 'none';
                document.getElementById('main-advice').textContent = room.generalAdvice;
                document.getElementById('tips-content').textContent = room.generalTips;
                document.getElementById('survival-content').textContent = room.generalSurvival;
            }
            
            document.getElementById('room-label').textContent = room.name;
            
            currentStress = ((room.noise + room.light + room.crowd) / 15) * 100;
            updateStressMeter();
        }

        function updateStressMeter() {
            const fill = document.getElementById('stress-fill');
            const label = document.getElementById('stress-label');
            
            fill.style.width = currentStress + '%';
            
            if (currentStress < 33) {
                label.textContent = 'Low - Comfortable';
            } else if (currentStress < 66) {
                label.textContent = 'Moderate - Manageable';
            } else {
                label.textContent = 'High - Overwhelming';
            }
        }

        function startTimer() {
            roomStartTime = Date.now();
            timerInterval = setInterval(() => {
                const elapsed = Math.floor((Date.now() - roomStartTime) / 1000);
                const minutes = Math.floor(elapsed / 60);
                const seconds = elapsed % 60;
                document.getElementById('time-display').textContent = 
                    minutes + ':' + (seconds < 10 ? '0' : '') + seconds;
            }, 1000);
        }

        function resetTimer() {
            roomStartTime = Date.now();
        }

        function updateMinimap() {
            const canvas = document.getElementById('minimap-canvas');
            const ctx = canvas.getContext('2d');
            const room = roomData[currentRoomIndex];
            const currentRoom = rooms[currentRoomIndex];
            
            ctx.clearRect(0, 0, 150, 150);
            
            ctx.strokeStyle = 'rgba(255,255,255,0.3)';
            ctx.strokeRect(10, 10, 130, 130);
            
            room.zones.forEach(zone => {
                const x = 75 + (zone.pos.x / room.size.x) * 130;
                const y = 75 + (zone.pos.z / room.size.z) * 130;
                ctx.fillStyle = 'rgba(102, 126, 234, 0.3)';
                ctx.beginPath();
                ctx.arc(x, y, 8, 0, Math.PI * 2);
                ctx.fill();
            });
            
            const localX = camera.position.x - currentRoom.xOffset;
            const localZ = camera.position.z;
            const playerX = 75 + (localX / room.size.x) * 130;
            const playerY = 75 + (localZ / room.size.z) * 130;
            
            ctx.fillStyle = '#4caf50';
            ctx.beginPath();
            ctx.arc(playerX, playerY, 5, 0, Math.PI * 2);
            ctx.fill();
            
            ctx.strokeStyle = '#4caf50';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(playerX, playerY);
            const angle = euler.y;
            ctx.lineTo(playerX + Math.sin(angle) * 10, playerY + Math.cos(angle) * 10);
            ctx.stroke();
        }

        let flashTimer = 0;
        let lastUpdate = 0;

        function animate() {
            requestAnimationFrame(animate);
            
            const direction = new THREE.Vector3();
            const speed = 0.15;
            
            if (moveState.forward) direction.z -= 1;
            if (moveState.backward) direction.z += 1;
            if (moveState.left) direction.x -= 1;
            if (moveState.right) direction.x += 1;
            
            direction.normalize();
            direction.applyQuaternion(camera.quaternion);
            direction.y = 0;
            direction.normalize();
            
            const newX = camera.position.x + direction.x * speed;
            const newZ = camera.position.z + direction.z * speed;
            
            if (!checkCollision(newX, camera.position.z)) {
                camera.position.x = newX;
            }
            if (!checkCollision(camera.position.x, newZ)) {
                camera.position.z = newZ;
            }
            
            if (Date.now() - lastUpdate > 500) {
                updateHUD();
                updateMinimap();
                lastUpdate = Date.now();
            }
            
            const room = roomData[currentRoomIndex];
            flashTimer += 0.05;
            
            if (room.effect === 'strobe') {
                const flicker = Math.random() > 0.7 ? 0.3 : 1;
                renderer.setClearColor(new THREE.Color(room.color).multiplyScalar(flicker * 0.25));
            } else if (room.effect === 'chaos') {
                const pulse = 0.5 + Math.sin(flashTimer * 3) * 0.3;
                renderer.setClearColor(new THREE.Color(room.color).multiplyScalar(pulse * 0.15));
            } else if (room.effect === 'calm') {
                renderer.setClearColor(new THREE.Color(room.color).multiplyScalar(0.12));
            } else {
                renderer.setClearColor(new THREE.Color(room.color).multiplyScalar(0.2));
            }
            
            renderer.render(scene, camera);
        }

        init();
    </script>
</body>
</html>
